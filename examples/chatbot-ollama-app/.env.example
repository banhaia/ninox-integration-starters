# Puerto del servidor Express
PORT=3031

# URL base de Ollama (local o remota)
# Local: http://localhost:11434
# Remota: https://tu-ollama-server.com
OLLAMA_BASE_URL=http://localhost:11434

# Modelo de Ollama a usar
OLLAMA_MODEL=llama3.2

# Integración Ninox para cache local de stock
CATALOG_SYNC_INTERVAL_MS=600000
NINOX_BASE_URL=https://api.test-ninox.com.ar
NINOX_TOKEN=
NINOX_TIMEOUT_MS=10000

# Cantidad máxima de productos de stock que se agregan al contexto del bot
STOCK_CONTEXT_MAX_PRODUCTS=8
